# Copy this file to ".env.local" and fill in your values.
# .env.local is git-ignored — NEVER commit real keys.

# Any OpenAI-compatible chat-completions endpoint (default: IONEXT).
LLM_API_KEY=your-provider-api-key-here
LLM_ENDPOINT=https://inference.ionext.ai/v1/chat/completions
LLM_MODEL=google/gemma-4-31B-it

# Presenter password for the CTF /admin control panel — set your own.
ADMIN_PASSWORD=change-me

# Only needed for the deployed multi-user session (shared level + rate-limit
# across serverless instances). Leave blank for local dev (uses in-memory).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
